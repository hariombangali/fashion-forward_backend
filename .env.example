PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/fashion-forward?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRE=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email (SendGrid / Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# WhatsApp (MSG91 / Meta Cloud API)
WHATSAPP_API_URL=https://graph.facebook.com/v17.0
WHATSAPP_PHONE_ID=your-phone-id
WHATSAPP_TOKEN=your-token

# Admin WhatsApp Number (for order alerts)
ADMIN_WHATSAPP=+919876543210

# Frontend URL
CLIENT_URL=http://localhost:5173

# Store Info (for bills)
STORE_NAME=Fashion Forward
STORE_ADDRESS=MG Road, Indore, MP - 452001
STORE_PHONE=+919876543210
STORE_GSTIN=
